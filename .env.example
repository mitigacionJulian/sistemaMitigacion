# Copie este archivo a .env en la raíz del repo y ajuste valores.
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)
# El archivo .env no se sube a Git (.gitignore).

# --- Django ---
DJANGO_SECRET_KEY=cambie-esta-clave-por-una-aleatoria-larga
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL (misma contraseña para Docker db + backend) ---
POSTGRES_DB=mitigacion_accidentes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambie-esta-contraseña
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Si usa Postgres local fuera de Docker (ej. pgAdmin en otro puerto), descomente y ajuste:
# POSTGRES_DB=reviNuwBD
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5434

# --- CORS / CSRF (frontend Vite) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT y recuperación de clave ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_HOURS=1

# --- PostGIS / GeoDjango (F0) ---
DJANGO_USE_POSTGIS=1
# Windows (OSGeo4W): descomente y ajuste rutas si manage.py falla al importar gdal
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal312.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll
